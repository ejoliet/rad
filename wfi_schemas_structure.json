            {
              "name": "ID_OBS: Observation ID",
              "type": "property",
              "datatype": "string",
              "description": "Placeholder.  Example value '0000101001001001001'"
            },
            {
              "name": "FILESET_ID: Dataset ID",
              "type": "property",
              "datatype": "string",
